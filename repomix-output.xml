                  try{
                    const tmpUrl = URL.createObjectURL(att.file);
                    const ocrRes = await Tesseract.recognize(tmpUrl, 'por');
                    if(ocrRes && ocrRes.data && typeof ocrRes.data.text === 'string') ocrText = ocrRes.data.text.trim();
